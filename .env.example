# DocuMind Docker Compose environment
# Copy this file to .env and replace every placeholder before running Docker Compose.

# MySQL
MYSQL_ROOT_PASSWORD=change-me-mysql-root-password
MYSQL_DATABASE=documind

# Spring Security JWT
# Use a long random value of at least 32 bytes.
JWT_SECRET=change-me-long-random-jwt-secret-at-least-32-bytes
JWT_ACCESS_TOKEN_EXPIRATION=24h
JWT_REFRESH_TOKEN_EXPIRATION=7d

# Initial admin bootstrap
# Used only when the admin account does not exist yet.
DOCUMIND_ADMIN_USERNAME=admin
DOCUMIND_ADMIN_PASSWORD=change-me-admin-password

# Browser CORS origins accepted by Spring Boot.
APP_CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# Backend waits for synchronous AI upload/query processing.
FASTAPI_CONNECT_TIMEOUT=5s
FASTAPI_RESPONSE_TIMEOUT=20m
FASTAPI_STREAM_TIMEOUT=20m

# Public frontend binding on the Docker host.
# For a reverse proxy, use FRONTEND_HOST=127.0.0.1 and proxy to FRONTEND_PORT.
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=80

# Ollama models
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_LLM_MODEL=exaone3.5:7.8b
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:8b
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=512
OLLAMA_NUM_THREAD=0

# AI server performance
CHUNK_SIZE=800
CHUNK_OVERLAP=50
CHUNK_MERGE_MIN_SIZE=300
EMBEDDING_BATCH_SIZE=64
UPLOAD_READ_CHUNK_BYTES=1048576

# RAG retrieval size. Lower values are faster; raise only after quality testing.
CHAT_DEFAULT_TOP_K=3
AI_DEFAULT_TOP_K=3
VITE_DEFAULT_TOP_K=3
VITE_API_BASE_URL=/api
