# DocuMind school web server environment
# Copy this file to .env on the school server and replace every placeholder.
# Do not commit the real .env file.

# MySQL
# IMPORTANT: this value is used only when the MySQL volume is first created.
# If the volume already exists, changing this line will not change MySQL's stored root password.
MYSQL_ROOT_PASSWORD=change-me-mysql-root-password
MYSQL_DATABASE=documind

# Spring Security JWT
JWT_SECRET=change-me-long-random-jwt-secret-at-least-32-bytes
JWT_ACCESS_TOKEN_EXPIRATION=24h
JWT_REFRESH_TOKEN_EXPIRATION=7d

# Initial admin bootstrap.
# IMPORTANT: replace the password before the first docker compose up.
# If the MySQL volume already has this username, changing .env will not reset the stored password.
DOCUMIND_ADMIN_USERNAME=admin
DOCUMIND_ADMIN_PASSWORD=change-me-admin-password

# School web origin accepted by Spring Boot.
# If you test by direct IP first, replace this with http://SERVER_IP:19580.
APP_CORS_ALLOWED_ORIGINS=http://mojuk.kr,http://mojuk.kr:19580,https://mojuk.kr,https://mojuk.kr:19580,http://localhost:19580,http://127.0.0.1:19580

# Backend waits for synchronous AI upload/query processing.
FASTAPI_CONNECT_TIMEOUT=5s
FASTAPI_RESPONSE_TIMEOUT=20m
FASTAPI_STREAM_TIMEOUT=20m
DOCUMENT_PROCESSING_ASYNC_ENABLED=true
DOCUMENT_PROCESSING_CORE_POOL_SIZE=1
DOCUMENT_PROCESSING_MAX_POOL_SIZE=1
DOCUMENT_PROCESSING_QUEUE_CAPACITY=20

# Bind frontend only to localhost. Apache/Nginx on the host should proxy public traffic here.
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=19580

# Use the Ollama process already running on the school host.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_LLM_MODEL=exaone3.5:7.8b
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:4b
OLLAMA_KEEP_ALIVE=30m
OLLAMA_EMBEDDING_WARMUP_ON_STARTUP=true
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=512
OLLAMA_NUM_THREAD=8

# AI server performance
CHUNK_SIZE=1200
CHUNK_OVERLAP=120
CHUNK_MERGE_MIN_SIZE=400
EMBEDDING_BATCH_SIZE=8
UPLOAD_READ_CHUNK_BYTES=1048576

# RAG retrieval size. Higher values improve recall but increase prompt length and answer latency.
CHAT_DEFAULT_TOP_K=5
AI_DEFAULT_TOP_K=5
VITE_DEFAULT_TOP_K=5
VITE_API_BASE_URL=/api
